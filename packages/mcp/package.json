{
  "name": "mdpilot-mcp",
  "version": "0.3.1",
  "description": "MCP server for MDPilot — generate AGENTS.md/CLAUDE.md, optimize tokens, and detect doc drift from inside your IDE.",
  "type": "module",
  "bin": {
    "mdpilot-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agents.md",
    "claude",
    "cursor",
    "windsurf",
    "ai",
    "markdown",
    "agents",
    "documentation"
  ],
  "author": "Mohan (Viveon Gizit Pvt Ltd)",
  "license": "MIT",
  "homepage": "https://mdpilot.in",
  "bugs": {
    "url": "https://github.com/get-mdpilot/Feedback/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "js-tiktoken": "^1.0.21",
    "openai": "^4.0.0",
    "repomix": "^1.14.1",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.0.0",
    "typescript": "^5"
  }
}
